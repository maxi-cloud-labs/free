{
	"module": "openclaw",
	"name": "Open Claw",
	"title": "AI Assistant",
	"category": "Personal",
	"version": "2026.2.6-3",
	"installMethod": "npm",
	"web": true,
	"essential": true,
	"finished": true,
	"ai": true,
	"database": "SQLite",
	"github": "openclaw/openclaw",
	"description": "A user-friendly personal AI assistant.",
	"keywords": [
		"AI assistant",
		"AI models",
		"LLMs",
		"Language",
		"Language model"
	],
	"proprietary": [],
	"default": {
		"addConfigBegin": "Alias /access /usr/local/modules/openclaw/access\n\t<Directory /usr/local/modules/openclaw/access>\n\t\tRequire all granted\n\t</Directory>\n\tProxyPass /access !",
		"autoLogin": {
			"inject": [
				{
					"url": "/access/index.php",
					"form": "form[id=formID]",
					"arg1": "input[id=tokenID]",
					"arg2": "",
					"arg3": "button[id=submitID]",
					"val1": 2,
					"val2": 4
				}
			],
			"post": [
				{
					"url": "/access/index.php",
					"arg1": "token",
					"arg2": "",
					"val1": 2,
					"val2": 4
				}
			]
		},
		"config": true,
		"enabled": true,
		"homepage": "/access",
		"localPort": 9475,
		"permissions": [],
		"permissionsPublicForbidden": true,
		"reset": true,
		"reverseProxy": [
			{
				"type": "http",
				"port": 18789,
				"path": "/"
			},
			{
				"type": "ws",
				"port": 18789,
				"path": "/"
			}
		],
		"services": [
			"openclaw"
		],
		"setup": true,
		"setupDependencies": []
	}
}
