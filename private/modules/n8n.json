{
	"module": "n8n",
	"name": "n8n",
	"title": "Workflow Automation",
	"category": "Knowledge",
	"version": "n8n@2.13.4",
	"installMethod": "npm",
	"web": true,
	"essential": false,
	"finished": true,
	"ai": true,
	"database": "",
	"github": "n8n-io/n8n",
	"description": "A fair-code workflow automation platform with native AI capabilities.",
	"keywords": [
		"n8n"
	],
	"proprietary": [],
	"default": {
		"autoLogin": {
			"inject": [
				{
					"url": "/",
					"form": "main[id=content]",
					"arg1": "input[id=emailOrLdapLoginId]",
					"arg2": "input[id=password]",
					"arg3": "button[type=button]",
					"val1": 1,
					"val2": 2
				},
				{
					"url": "/signin",
					"form": "main[id=content]",
					"arg1": "input[id=emailOrLdapLoginId]",
					"arg2": "input[id=password]",
					"arg3": "button[type=button]",
					"val1": 1,
					"val2": 2
				}
			],
			"post": [
				{
					"url": "/rest/login",
					"arg1": "emailOrLdapLoginId",
					"arg2": "password",
					"val1": 1,
					"val2": 2
				}
			]
		},
		"autoLoginNoGzip": [
			"^/$",
			"^/signin"
		],
		"config": true,
		"enabled": true,
		"localPort": 9548,
		"permissions": [],
		"reset": true,
		"reverseProxy": [
			{
				"type": "http",
				"port": 5678,
				"path": "/"
			}
		],
		"services": [
			"n8n"
		],
		"setup": true,
		"setupDependencies": []
	}
}
