{
	"module": "jellyfin",
	"name": "Jellyfin",
	"title": "Media Streaming",
	"category": "Media",
	"version": "v10.10.7",
	"installMethod": "clone",
	"web": true,
	"essential": false,
	"finished": true,
	"ai": false,
	"database": "SQLite",
	"github": "jellyfin/jellyfin",
	"description": "A media server for audio, video, books, comics, and photos with a sleek interface and robust transcoding capabilities.",
	"keywords": [
		"Home server",
		"Media management",
		"Media streaming",
		"Streaming",
		"Video",
		"Video streaming"
	],
	"proprietary": [
		"Emby",
		"Plex"
	],
	"default": {
		"autoLogin": {
			"inject": [
				{
					"url": "/web/",
					"form": "form[class*=manualLoginForm]",
					"arg1": "input[id=txtManualName]",
					"arg2": "input[id=txtManualPassword]",
					"arg3": "button[type=submit]",
					"val1": 0,
					"val2": 2
				}
			],
			"post": [
				{
					"url": "/Users/authenticatebyname",
					"arg1": "username",
					"arg2": "password",
					"val1": 0,
					"val2": 2
				}
			]
		},
		"autoLoginNoGzip": [
			"^/web/$"
		],
		"enabled": true,
		"localPort": 9448,
		"permissions": [
			"user"
		],
		"reset": true,
		"reverseProxy": [
			{
				"type": "http",
				"port": 8096,
				"path": "/"
			}
		],
		"services": [
			"jellyfin"
		],
		"setup": true,
		"setupDependencies": [],
		"setupRoot": true
	}
}
