[Unit]
Description=Promptfoo
After=network.target
StartLimitBurst=5
StartLimitIntervalSec=300s
OnFailure=notify-failure@%n.service

[Service]
Restart=on-failure
RestartMode=direct
Type=simple
StandardOutput=inherit
StandardError=inherit
RestartSec=5s
User=admin
ExecStart=/usr/local/modules/promptfoo/node_modules/.bin/promptfoo view
WorkingDirectory=/disk/admin/modules/promptfoo

[Install]
WantedBy=multi-user.target
