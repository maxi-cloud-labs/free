[Unit]
Description=Redis Commander
After=network.target
StartLimitBurst=5
StartLimitIntervalSec=300s
OnFailure=notify-failure@%n.service

[Service]
Restart=on-failure
RestartMode=direct
Type=simple
StandardOutput=inherit
StandardError=inherit
RestartSec=5s
User=admin
ExecStart=/usr/local/modules/rediscommander/node_modules/.bin/redis-commander -a 127.0.0.1 -p 8119
WorkingDirectory=/usr/local/modules/rediscommander

[Install]
WantedBy=multi-user.target
