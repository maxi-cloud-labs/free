[Unit]
Description=Rocket.Chat
After=network.target
StartLimitBurst=5
StartLimitIntervalSec=300s
OnFailure=notify-failure@%n.service

[Service]
Restart=on-failure
RestartMode=direct
Type=simple
StandardOutput=inherit
StandardError=inherit
RestartSec=5s
User=admin
ExecStart=/usr/local/bin/node /usr/local/modules/rocketchat/main.js
WorkingDirectory=/disk/admin/modules/rocketchat
Environment=ROOT_URL=http://localhost:3100
Environment=PORT=3100

[Install]
WantedBy=multi-user.target
