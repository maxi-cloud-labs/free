[Unit]
Description=Portkey
After=network.target
StartLimitBurst=5
StartLimitIntervalSec=300s
OnFailure=notify-failure@%n.service

[Service]
Restart=on-failure
RestartMode=direct
Type=simple
StandardOutput=inherit
StandardError=inherit
RestartSec=5s
User=admin
ExecStart=/usr/local/modules/portkey/node_modules/.bin/gateway
WorkingDirectory=/disk/admin/modules/portkey

[Install]
WantedBy=multi-user.target
