[Unit]
Description=Silver Bullet
After=network.target
StartLimitBurst=5
StartLimitIntervalSec=300s
OnFailure=notify-failure@%n.service

[Service]
Restart=on-failure
RestartMode=direct
Type=simple
StandardOutput=inherit
StandardError=inherit
RestartSec=5s
User=admin
ExecStart=/usr/local/bin/silverbullet /disk/admin/modules/silverbullet
WorkingDirectory=/disk/admin/modules/silverbullet
Environment=SB_PORT=8121

[Install]
WantedBy=multi-user.target
