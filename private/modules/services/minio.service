[Unit]
Description=MinIO
After=network.target
StartLimitBurst=5
StartLimitIntervalSec=300s
OnFailure=notify-failure@%n.service

[Service]
Restart=on-failure
RestartMode=direct
Type=simple
StandardOutput=inherit
StandardError=inherit
RestartSec=5s
User=admin
ExecStart=/usr/local/bin/minio server /disk/admin/modules/minio --console-address "localhost:9001"
WorkingDirectory=/disk/admin/modules/minio
EnvironmentFile=/disk/admin/modules/minio/minio.env

[Install]
WantedBy=multi-user.target
